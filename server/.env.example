DATABASE_URL="file:./dev.db"
PORT=4000

# Admin Authentication — JWT
# Generate a bcrypt hash of your admin PIN:
#   node -e "const b=require('bcryptjs'); console.log(b.hashSync('YOUR_PIN',12));"
ADMIN_PIN_HASH="REPLACE_WITH_BCRYPT_HASH"

# JWT signing secret (min 64 chars):
#   node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET="REPLACE_WITH_RANDOM_HEX_STRING"
JWT_EXPIRES_IN="4h"

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
