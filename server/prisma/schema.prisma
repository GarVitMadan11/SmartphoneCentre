// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — ReliableExchange Full-Stack Backend
// Database: SQLite (development) → PostgreSQL (production via DATABASE_URL)
// To switch: change provider to "postgresql" and update DATABASE_URL in .env
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Master Catalog ────────────────────────────────────────────────────────────

model Brand {
  id     String  @id @default(uuid())
  name   String
  logo   String
  active Boolean @default(true)

  models Model[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Model {
  id             String @id @default(uuid())
  legacyId       String @unique // e.g. "apple-16pm" — maps to frontend IDs
  brandId        String
  name           String
  modelNumber    String
  category       String // flagship | premium | midrange | budget
  releaseYear    Int
  basePrice128GB Int    // Anchor price in INR
  series         String @default("")
  imageUrl       String @default("") // optional external image URL

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([category])
}

// ── Trade-In Bookings ─────────────────────────────────────────────────────────

model Booking {
  id                 String @id // server-generated: "STC-XXXXXXXX"
  modelLegacyId      String // references Model.legacyId
  modelName          String
  modelNumber        String @default("")
  storageGb          Int
  color              String
  customerName       String
  customerPhone      String
  customerEmail      String
  address            String
  pickupDate         String
  pickupTimeSlot     String
  finalPrice         Int
  verificationStatus String @default("pending") // pending | verified | failed
  verifiedName       String @default("")
  maskedAadhaar      String @default("")
  verificationDate   String @default("")
  payoutMethod       String
  payoutMethodName   String
  bonusPercentage    Float  @default(0)
  bonusAmount        Int    @default(0)
  finalPayoutAmount  Int
  inspectionStatus   String @default("pending") // pending | approved | rejected
  payoutStatus       String @default("pending") // pending | completed
  dateCreated        String
  adminNotes         String @default("")        // internal admin notes

  // Payout details stored as JSON string
  payoutDetailsJson String @default("{}")

  events BookingEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inspectionStatus])
  @@index([payoutStatus])
  @@index([createdAt])
  @@index([customerPhone])
}

// ── Booking Lifecycle Events ──────────────────────────────────────────────────
// Append-only log: one record per status change or admin action on a booking.

model BookingEvent {
  id        String @id @default(uuid())
  bookingId String
  eventType String // status_change | admin_note | created | verified
  fromValue String @default("")
  toValue   String @default("")
  note      String @default("")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([createdAt])
}

// ── Admin Audit Log ───────────────────────────────────────────────────────────
// Immutable record of all admin actions for accountability.

model AdminAuditLog {
  id          String @id @default(uuid())
  action      String // create_model | delete_model | update_booking_status | etc.
  targetType  String // "booking" | "model" | "brand"
  targetId    String // the affected record's ID
  payload     String @default("{}") // JSON: what changed
  ipAddress   String @default("")
  userAgent   String @default("")

  createdAt DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}
