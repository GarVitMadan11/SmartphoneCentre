{
  "name": "smartphone-centre",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
    "db:setup": "cd server && npx prisma migrate dev --name init && npx tsx prisma/seed.ts",
    "db:seed": "cd server && npx tsx prisma/seed.ts",
    "dev:fullstack": "concurrently -n FE,BE -c cyan,green \"npm run dev\" \"npm run server\""
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "canvas-confetti": "^1.9.3",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-icons": "^16.25.0"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.6.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "duck-duck-scrape": "^2.2.7",
    "postcss": "^8.4.38",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^8.1.3",
    "vite-plugin-image-optimizer": "^2.0.3"
  }
}
